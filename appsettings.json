/*
  to publish and deploy app, store settings here. we usually store app config settings
  or environment settings like appsettings.staging.environment.json
  similarly for development environment, we will have appsettings.development.json
*/
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "MyKey":  "Value of MyKey from appsettings.json"
}
